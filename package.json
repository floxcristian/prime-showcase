{
  "name": "prime-showcase",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && node tools/fonts/inject-preload.mjs",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint && npm run lint:rules:test && npm run fonts:preload:test && npm run design-tokens:test && npm run design-tokens:check",
    "lint:fix": "ng lint --fix",
    "lint:rules:test": "node --test tools/eslint/rules/__tests__/*.test.js",
    "fonts:preload:test": "node --test tools/fonts/__tests__/*.test.mjs",
    "design-tokens:test": "node --test tools/design-tokens/__tests__/*.test.mjs",
    "design-tokens:check": "node tools/design-tokens/sync.mjs",
    "design-tokens:sync": "node tools/design-tokens/sync.mjs --update",
    "visual": "playwright test --project=visual",
    "visual:update": "playwright test --project=visual --update-snapshots",
    "visual:baseline": "tools/visual/baseline.sh",
    "a11y": "playwright test --project=a11y",
    "storybook": "ng run prime-showcase:storybook",
    "build-storybook": "ng run prime-showcase:build-storybook",
    "test": "ng test",
    "test:ssr:smoke": "node tools/smoke/ssr-theme.smoke.mjs",
    "bundle:check": "node tools/bundle/check-delta.mjs",
    "bundle:baseline": "node tools/bundle/check-delta.mjs --update-baseline",
    "serve:ssr:prime-showcase": "node dist/prime-showcase/server/server.mjs",
    "verify": "npm run lint && npm run build && npm run bundle:check && node tools/smoke/run-with-server.mjs",
    "postinstall": "patch-package"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-server": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/ssr": "^21.2.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "primeng": "^21.1.5",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/angular": "^10.3.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "patch-package": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
