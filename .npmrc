# npm configuration for prime-showcase.
#
# legacy-peer-deps=true
#   Angular 17+ ecosystem reality: peer-dependency declarations across
#   @angular/*, ng-packagr, and adjacent tooling (Storybook, Karma, NX)
#   over-tighten patch-level pins. npm 7+ resolves strictly and produces
#   spurious ERESOLVE failures when, e.g., @angular/localize@21.2.12
#   demands @angular/compiler@21.2.12 but the lockfile has 21.2.10.
#
#   This flag falls back to npm 6 semantics: emit a warning, continue
#   the install. Project-wide because every contributor and every CI
#   run must hit the same resolution behavior — solving it ad-hoc on
#   the command line leaves a trap for the next dev.
#
#   Posture matches Angular Components (Material), Nrwl Nx, AnalogJS,
#   and the official Angular CLI starter generated from `ng new`.
legacy-peer-deps=true

# save-exact=false
#   Keep the caret (^) prefix on `npm install`. The lockfile pins exact
#   versions for reproducibility; the manifest expresses the intentional
#   semver range so dependabot/renovate can propose minor bumps within
#   it. Default already, declared here for documentation.
save-exact=false
